{
  "redirects": [
    {
      "source": "/",
      "destination": "/bb",
      "permanent": true,
      "has": [{"type": "host", "value": "bigbrotherdle.com"}]
    },
    {
      "source": "/:path*",
      "destination": "/bb/:path*",
      "permanent": true,
      "has": [{"type": "host", "value": "bigbrotherdle.com"}]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}